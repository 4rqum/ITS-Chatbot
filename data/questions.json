{
  "_comment": "UMich-ITS Chatbot - Diagnostic Questions (3-intent prototype: Okta, VPN, MPrint).",
  "schema_version": 1,

  "_comment_design": [
    "Ask universal questions first (2-4 max for v1).",
    "Then ask 2 intent-specific questions for the top intent (or 1+1 if tie).",
    "Store answers in ConversationState.answers[store_key].",
    "Types: yesno | choice | text"
  ],

  "universal": [
    {
      "id": "u_device_scope",
      "text": "Is this happening on just one device, or multiple devices?",
      "type": "choice",
      "options": ["one", "multiple", "not_sure"],
      "store_key": "device_scope"
    },
    {
      "id": "u_location",
      "text": "Where are you right now?",
      "type": "choice",
      "options": ["on_campus", "off_campus", "not_sure"],
      "store_key": "location",
      "_comment": "Useful for VPN expectations and some sign-in behaviors."
    },
    {
      "id": "u_start_time",
      "text": "When did this start?",
      "type": "choice",
      "options": ["today", "last_few_days", "weeks_or_more", "not_sure"],
      "store_key": "start_time"
    },
    {
      "id": "u_recent_change",
      "text": "Did anything change right before this started? (new device, password reset, update, etc.)",
      "type": "choice",
      "options": ["yes", "no", "not_sure"],
      "store_key": "recent_change"
    }
  ],

  "intent_specific": {
    "duo_okta_authentication": [
      {
        "id": "o_problem_type",
        "text": "What best describes the Okta problem?",
        "type": "choice",
        "options": [
          "cant_enroll",
          "push_not_arriving",
          "stuck_loading",
          "looping_login",
          "new_phone",
          "fastpass_issue",
          "not_sure"
        ],
        "store_key": "okta_symptom"
      },
      {
        "id": "o_method",
        "text": "How are you trying to approve the sign-in?",
        "type": "choice",
        "options": ["push", "code", "security_key", "token", "not_sure"],
        "store_key": "okta_method",
        "_comment": "Lets you direct them to push vs enter-code vs token steps."
      }
    ],

    "vpn_remote_access": [
      {
        "id": "v_client",
        "text": "Which VPN client are you using?",
        "type": "choice",
        "options": ["umvpn", "anyconnect", "secureclient", "not_sure"],
        "store_key": "vpn_client"
      },
      {
        "id": "v_error",
        "text": "What happens when you try to connect?",
        "type": "choice",
        "options": [
          "cant_connect",
          "auth_failed",
          "connected_no_access",
          "disconnects",
          "installation_issue",
          "not_sure"
        ],
        "store_key": "vpn_symptom"
      }
    ],

    "printing_mprint_setup": [
      {
        "id": "p_where_printing",
        "text": "Where are you trying to print?",
        "type": "choice",
        "options": ["campus_mprint", "department_printer", "personal_printer", "not_sure"],
        "store_key": "print_environment"
      },
      {
        "id": "p_symptom",
        "text": "What’s happening with your print job?",
        "type": "choice",
        "options": [
          "wont_print",
          "stuck_in_queue",
          "cant_find_printer",
          "cant_release",
          "prints_wrong",
          "not_sure"
        ],
        "store_key": "print_symptom"
      }
    ]
  },

  "_comment_tiebreaker_policy": "If top 2 intent scores are close, ask 1 question from each and rescore.",
  "tie_breaking": {
    "enabled": true,
    "max_extra_questions": 2
  }
}